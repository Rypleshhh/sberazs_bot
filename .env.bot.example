ROLE=bot

BOT_TOKEN=получите_у_BotFather

# Тот же токен, что вписан в API_TOKEN на мощном сервере
API_TOKEN=придумайте_длинный_случайный_токен

# Адрес мощного сервера (белый IP + порт из docker-compose.scraper.yml)
SCRAPER_API_URL=http://IP_МОЩНОГО_СЕРВЕРА:8080

# Необязательные:
# POLL_INTERVAL_SEC=30
# BOT_DB_PATH=/app/data/bot.db
