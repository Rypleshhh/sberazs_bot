# Обязательно — иначе конфиг потребует BOT_TOKEN, который тут не нужен
ROLE=scraper

# Общий секрет с лёгким сервером — придумайте длинную случайную строку
API_TOKEN=придумайте_длинный_случайный_токен

# Необязательные:
# SCAN_INTERVAL_MINUTES=12
# MAX_PAYMENT_AGE_MINUTES=20
# STEP_LON=0.3
# STEP_LAT=0.2
# REQUEST_DELAY_SEC=0.4
# DB_PATH=/app/data/stations.db
